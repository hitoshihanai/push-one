---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- ===== スプラッシュ ===== -->
<div id="splash" aria-hidden="true">
  <div class="splash-inner">
    <span class="splash-text">PUSH ONE</span>
  </div>
</div>

<!-- ===== APP ROOT ===== -->
<div id="app">

  <!-- ===== HOME VIEW ===== -->
  <section id="view-home" class="view active" aria-label="ホーム">
    <div class="home-content">

      <!-- ストリーク表示 -->
      <div class="home-top">
        <div class="streak-wrap">
          <span class="streak-number" id="streak-number">0</span>
          <div class="streak-meta">
            <span class="streak-unit">日</span>
            <span class="streak-label">連続</span>
          </div>
        </div>
      </div>

      <!-- メインCTA -->
      <div class="cta-wrap">
        <p class="today-question" id="today-question">今日、やった？</p>

        <button class="cta-btn" id="complete-btn" aria-label="1回やった">
          <span class="cta-btn-text">1回やった</span>
        </button>

        <!-- 達成後表示 -->
        <div class="done-state" id="done-state" aria-live="polite">
          <div class="check-ring">
            <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
              <circle cx="24" cy="24" r="22" stroke="#30d158" stroke-width="2"/>
              <path d="M14 24l7 7 13-13" stroke="#30d158" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="done-msg" id="done-msg">ナイス1回。</p>
        </div>
      </div>

      <!-- 累計 -->
      <div class="home-bottom">
        <span class="total-label">累計 <span id="total-count">0</span> 日</span>
      </div>

    </div>
  </section>

  <!-- ===== RECORD VIEW ===== -->
  <section id="view-record" class="view" aria-label="記録">
    <div class="record-content">

      <h1 class="view-heading">記録</h1>

      <!-- 統計カード -->
      <div class="stats-row">
        <div class="stat-card">
          <span class="stat-val" id="rec-streak">0</span>
          <span class="stat-lbl">日連続</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="rec-total">0</span>
          <span class="stat-lbl">累計</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="rec-month">0</span>
          <span class="stat-lbl">今月</span>
        </div>
      </div>

      <!-- カレンダー -->
      <div class="cal-card">
        <div class="cal-nav">
          <button class="cal-nav-btn" id="prev-month" aria-label="前の月">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <span class="cal-month-label" id="month-label">2026年5月</span>
          <button class="cal-nav-btn" id="next-month" aria-label="次の月">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>

        <div class="cal-weekdays" aria-hidden="true">
          <span>日</span><span>月</span><span>火</span>
          <span>水</span><span>木</span><span>金</span><span>土</span>
        </div>

        <div class="cal-grid" id="cal-grid" role="grid" aria-label="達成カレンダー"></div>
      </div>

    </div>
  </section>

  <!-- ===== SETTINGS VIEW ===== -->
  <section id="view-settings" class="view" aria-label="設定">
    <div class="settings-content">

      <h1 class="view-heading">設定</h1>

      <!-- 通知グループ -->
      <div class="settings-group">
        <div class="setting-row">
          <div class="setting-info">
            <span class="setting-title">通知</span>
            <span class="setting-desc">毎日リマインドを受け取る</span>
          </div>
          <label class="toggle" aria-label="通知ON/OFF">
            <input type="checkbox" id="notif-toggle" />
            <span class="toggle-track"></span>
          </label>
        </div>

        <div class="setting-row" id="time-row">
          <div class="setting-info">
            <span class="setting-title">通知時刻</span>
          </div>
          <input type="time" id="notif-time" value="21:00" class="time-input"
                 aria-label="通知時刻" />
        </div>

        <div class="setting-row">
          <div class="setting-info">
            <span class="setting-title">文言スタイル</span>
          </div>
          <select id="notif-style" class="select-input" aria-label="通知文言スタイル">
            <option value="gentle">やさしめ</option>
            <option value="stoic">ストイック</option>
            <option value="minimal">ミニマル</option>
          </select>
        </div>
      </div>

      <!-- 通知ステータス -->
      <div class="notif-status-card">
        <p class="notif-status-text" id="notif-status-text">
          通知をONにすると、毎日リマインドをお届けします。
        </p>
        <button class="test-btn" id="test-notif-btn">
          テスト通知を送る
        </button>
      </div>

      <!-- データリセット -->
      <div class="settings-group">
        <div class="setting-row">
          <button class="danger-btn" id="reset-btn">
            データをリセット
          </button>
        </div>
      </div>

      <!-- アプリ情報 -->
      <footer class="app-info">
        <p class="app-info-name">PUSH ONE</p>
        <p class="app-info-sub">Everyday Push-up</p>
        <p class="app-info-ver">v1.0.0</p>
      </footer>

    </div>
  </section>

  <!-- ===== BOTTOM NAV ===== -->
  <nav class="bottom-nav" aria-label="メインナビゲーション">
    <button class="nav-item active" data-view="home" aria-label="ホーム">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1z"/>
        <path d="M9 21V12h6v9"/>
      </svg>
      <span>ホーム</span>
    </button>
    <button class="nav-item" data-view="record" aria-label="記録">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <span>記録</span>
    </button>
    <button class="nav-item" data-view="settings" aria-label="設定">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
      </svg>
      <span>設定</span>
    </button>
  </nav>

</div><!-- /#app -->

</Layout>

<!-- ===== GLOBAL STYLES ===== -->
<style is:global>
  /* CSS変数 */
  :root {
    --bg:           #f2f2f7;
    --bg-raised:    #ffffff;
    --bg-card:      #ffffff;
    --text:         #1c1c1e;
    --text-2:       rgba(0,0,0,0.50);
    --text-3:       rgba(0,0,0,0.30);
    --border:       rgba(0,0,0,0.10);
    --success:      #30d158;
    --danger:       #ff3b30;
    --nav-h:        76px;
    --safe-b:       env(safe-area-inset-bottom, 0px);
    --safe-t:       env(safe-area-inset-top, 0px);
  }

  /* ===========================
     スプラッシュスクリーン
  =========================== */
  #splash {
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    pointer-events: none;
  }

  #splash.hidden {
    display: none;
  }

  .splash-inner {
    overflow: hidden;
  }

  .splash-text {
    display: block;
    font-size: 36px;
    font-weight: 800;
    letter-spacing: 8px;
    color: var(--text);
    transform: translateX(-110%);
    animation: splash-slide 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  @keyframes splash-slide {
    from { transform: translateX(-110%); opacity: 0; }
    to   { transform: translateX(0);     opacity: 1; }
  }

  #splash.fade-out {
    animation: splash-fade 0.4s ease forwards;
  }

  @keyframes splash-fade {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  /* リセット */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    height: 100%;
    background: var(--bg);
    overflow: hidden;
  }

  body {
    height: 100%;
    overflow: hidden;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue',
                 system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -webkit-text-size-adjust: 100%;
    text-rendering: optimizeLegibility;
  }

  /* ===== APP ROOT ===== */
  #app {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding-top: var(--safe-t);
  }

  /* ===== VIEW SYSTEM ===== */
  .view {
    display: none;
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    padding-bottom: calc(var(--nav-h) + var(--safe-b) + 16px);
  }

  .view.active {
    display: flex;
    flex-direction: column;
  }

  /* ===========================
     HOME VIEW
  =========================== */
  .home-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 40px 32px 24px;
    min-height: 0;
  }

  /* ストリーク */
  .home-top {
    display: flex;
    align-items: flex-start;
    padding-top: 8px;
  }

  .streak-wrap {
    display: flex;
    align-items: flex-end;
    gap: 6px;
  }

  .streak-number {
    font-size: 80px;
    font-weight: 700;
    letter-spacing: -4px;
    line-height: 1;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    transition: color 0.4s ease;
  }

  .streak-meta {
    display: flex;
    flex-direction: column;
    padding-bottom: 12px;
    gap: 1px;
  }

  .streak-unit {
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.5px;
  }

  .streak-label {
    font-size: 12px;
    color: var(--text-2);
    letter-spacing: 0.5px;
  }

  /* CTA エリア */
  .cta-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .today-question {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.5px;
    transition: opacity 0.4s ease;
  }

  /* メインボタン */
  .cta-btn {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: var(--text);
    color: var(--bg);
    border: none;
    font-size: 20px;
    font-weight: 700;
    font-family: inherit;
    letter-spacing: -0.3px;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 0 rgba(0,0,0,0.08),
                0 8px 32px rgba(0,0,0,0.18);
  }

  .cta-btn:active {
    transform: scale(0.93);
  }

  @keyframes btn-complete {
    0%   { transform: scale(1); }
    25%  { transform: scale(0.90); }
    65%  { transform: scale(1.05); }
    100% { transform: scale(1); }
  }

  .cta-btn.completing {
    animation: btn-complete 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* 達成後の表示 */
  .done-state {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .done-state.visible {
    display: flex;
    animation: fade-up 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .check-ring {
    width: 72px;
    height: 72px;
    animation: check-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes check-pop {
    from { opacity: 0; transform: scale(0.3); }
    to   { opacity: 1; transform: scale(1); }
  }

  .done-msg {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.3px;
    color: var(--text);
  }

  /* フッター累計 */
  .home-bottom {
    display: flex;
    justify-content: center;
  }

  .total-label {
    font-size: 13px;
    color: var(--text-3);
    letter-spacing: 0.5px;
    font-variant-numeric: tabular-nums;
  }

  /* ===========================
     RECORD VIEW
  =========================== */
  .record-content {
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .view-heading {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.8px;
    padding: 4px 0 0;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .stat-card {
    background: var(--bg-card);
    border-radius: 16px;
    padding: 16px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--border);
  }

  .stat-val {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1.5px;
    font-variant-numeric: tabular-nums;
  }

  .stat-lbl {
    font-size: 11px;
    color: var(--text-2);
    letter-spacing: 0.3px;
  }

  /* カレンダーカード */
  .cal-card {
    background: var(--bg-card);
    border-radius: 20px;
    padding: 18px 16px 20px;
    border: 1px solid var(--border);
  }

  .cal-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .cal-month-label {
    font-size: 15px;
    font-weight: 600;
  }

  .cal-nav-btn {
    background: none;
    border: none;
    color: var(--text-2);
    cursor: pointer;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s, background 0.2s;
  }

  .cal-nav-btn svg {
    width: 18px;
    height: 18px;
  }

  .cal-nav-btn:active {
    background: var(--border);
    color: var(--text);
  }

  .cal-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    margin-bottom: 6px;
  }

  .cal-weekdays span {
    font-size: 11px;
    color: var(--text-3);
    padding: 4px 0;
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  /* カレンダーセル */
  .cal-day {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    gap: 3px;
    position: relative;
  }

  .cal-day-num {
    font-size: 12px;
    color: var(--text-2);
    line-height: 1;
  }

  .cal-day.today .cal-day-num {
    color: var(--text);
    font-weight: 700;
  }

  .cal-day.future .cal-day-num {
    opacity: 0.18;
  }

  .cal-day.done {
    background: rgba(48, 209, 88, 0.09);
    border-radius: 10px;
  }

  .cal-day.done .cal-day-num {
    color: var(--success);
    font-weight: 600;
  }

  .cal-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--success);
    flex-shrink: 0;
  }

  /* ===========================
     SETTINGS VIEW
  =========================== */
  .settings-content {
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .settings-group {
    background: var(--bg-card);
    border-radius: 16px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
  }

  .setting-row + .setting-row {
    border-top: 1px solid var(--border);
  }

  .setting-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .setting-title {
    font-size: 15px;
    font-weight: 500;
  }

  .setting-desc {
    font-size: 12px;
    color: var(--text-2);
  }

  /* トグルスイッチ */
  .toggle {
    position: relative;
    width: 51px;
    height: 31px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .toggle input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-track {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.12);
    border-radius: 999px;
    transition: background 0.28s ease;
    cursor: pointer;
  }

  .toggle-track::before {
    content: '';
    position: absolute;
    width: 27px;
    height: 27px;
    left: 2px;
    top: 2px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 2px 6px rgba(0,0,0,0.35);
  }

  .toggle input:checked + .toggle-track {
    background: var(--success);
  }

  .toggle input:checked + .toggle-track::before {
    transform: translateX(20px);
  }

  /* 時間入力 */
  .time-input {
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 15px;
    padding: 7px 12px;
    font-family: inherit;
    cursor: pointer;
    outline: none;
    flex-shrink: 0;
  }

  .time-input:focus {
    border-color: rgba(255,255,255,0.25);
  }

  /* セレクト */
  .select-input {
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    padding: 7px 10px;
    font-family: inherit;
    cursor: pointer;
    outline: none;
    flex-shrink: 0;
    -webkit-appearance: none;
    appearance: none;
  }

  /* 通知ステータスカード */
  .notif-status-card {
    background: var(--bg-card);
    border-radius: 16px;
    padding: 16px 18px;
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .notif-status-text {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.6;
  }

  .test-btn {
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-2);
    font-size: 14px;
    font-family: inherit;
    padding: 10px 16px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.2s, color 0.2s;
    text-align: left;
  }

  .test-btn:active {
    background: rgba(0,0,0,0.08);
    color: var(--text);
  }

  /* 危険操作 */
  .danger-btn {
    background: none;
    border: none;
    color: var(--danger);
    font-size: 15px;
    font-family: inherit;
    cursor: pointer;
    padding: 2px 0;
    -webkit-tap-highlight-color: transparent;
    opacity: 0.85;
  }

  .danger-btn:active {
    opacity: 1;
  }

  /* アプリ情報 */
  .app-info {
    text-align: center;
    padding: 8px 0 4px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .app-info-name {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--text-3);
