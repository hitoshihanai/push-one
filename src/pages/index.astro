<!-- ===== CLIENT SCRIPT ===== -->
<script>
// ================================================
// 定数
// ================================================
const WORKER_URL = 'https://push-one-server.hitoshi-hanai.workers.dev';
const VAPID_PUBLIC_KEY = 'BEeZKZ053r9rgQuiFwk6HuLz_dEJrLLmSfgBMiT5RpVxYr6vbgqz4w-Rvb0ElnkBQr4M_QBIGK2MnDu3uDuhMhY';

// ================================================
// スプラッシュ
// ================================================
function hideSplash(): void {
  const splash = document.getElementById('splash') as HTMLElement;
  splash.classList.add('fade-out');
  splash.addEventListener('animationend', () => splash.classList.add('hidden'), { once: true });
}

// ================================================
// データ管理
// ================================================
const STORAGE_KEY = 'pushone_v1';

interface AppData {
  completedDates: string[];
  notificationEnabled: boolean;
  notificationTime: string;
  notificationStyle: string;
}

function defaultData(): AppData {
  return {
    completedDates: [],
    notificationEnabled: false,
    notificationTime: '21:00',
    notificationStyle: 'gentle',
  };
}

function getData(): AppData {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return defaultData();
    return { ...defaultData(), ...JSON.parse(raw) };
  } catch {
    return defaultData();
  }
}

function saveData(data: AppData): void {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
}

// ================================================
// 日付ヘルパー
// ================================================
function getToday(): string {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}

function dateStr(d: Date): string {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}

function isTodayDone(): boolean {
  return getData().completedDates.includes(getToday());
}

function calcStreak(dates: string[]): number {
  if (!dates.length) return 0;
  const set = new Set(dates);
  const cur = new Date();
  // 今日未達成なら昨日から連続チェック開始
  if (!set.has(getToday())) cur.setDate(cur.getDate() - 1);
  let streak = 0;
  while (set.has(dateStr(cur))) {
    streak++;
    cur.setDate(cur.getDate() - 1);
  }
  return streak;
}

function monthCount(dates: string[], year: number, month: number): number {
  const prefix = `${year}-${String(month + 1).padStart(2, '0')}-`;
  return dates.filter((d) => d.startsWith(prefix)).length;
}

// ================================================
// 達成メッセージ
// ================================================
const ACHIEVEMENTS = [
  'ナイス1回。',
  '0→1、完了。',
  '継続は才能。',
  '勝ち。',
  '今日もゼロ回回避。',
  'それでいい。',
  '一歩、前進。',
  'いいね。',
  'ゼロじゃない。',
];

function randomAchievement(): string {
  return ACHIEVEMENTS[Math.floor(Math.random() * ACHIEVEMENTS.length)];
}

// ================================================
// ビュー切り替え
// ================================================
let currentView = 'home';
let calMonth = new Date();

function switchView(viewId: string): void {
  if (currentView === viewId) return;
  currentView = viewId;

  document.querySelectorAll<HTMLElement>('.view').forEach((v) => {
    v.classList.toggle('active', v.id === `view-${viewId}`);
  });
  document.querySelectorAll<HTMLElement>('.nav-item').forEach((n) => {
    n.classList.toggle('active', n.dataset.view === viewId);
  });

  if (viewId === 'record') renderRecord();
  if (viewId === 'settings') renderSettings();
}

// ================================================
// ホームビュー
// ================================================
function renderHome(): void {
  const data = getData();
  const streak = calcStreak(data.completedDates);
  const done = isTodayDone();

  (document.getElementById('streak-number') as HTMLElement).textContent = String(streak);
  (document.getElementById('total-count') as HTMLElement).textContent =
    String(data.completedDates.length);

  const btn = document.getElementById('complete-btn') as HTMLButtonElement;
  const doneState = document.getElementById('done-state') as HTMLElement;
  const question = document.getElementById('today-question') as HTMLElement;

  if (done) {
    btn.style.display = 'none';
    doneState.classList.add('visible');
    question.textContent = 'やった。';
    question.style.opacity = '0.35';
  } else {
    btn.style.display = '';
    doneState.classList.remove('visible');
    question.textContent = '今日、やった？';
    question.style.opacity = '1';
  }
}

function handleComplete(): void {
  if (isTodayDone()) return;

  const btn = document.getElementById('complete-btn') as HTMLButtonElement;
  btn.classList.add('completing');
  btn.disabled = true;

  // 触覚フィードバック（対応デバイスのみ）
  if ('vibrate' in navigator) navigator.vibrate([12, 40, 12]);

  setTimeout(() => {
    // データ保存
    const data = getData();
    const today = getToday();
    if (!data.completedDates.includes(today)) data.completedDates.push(today);
    saveData(data);

    const streak = calcStreak(data.completedDates);

    // DOM更新
    (document.getElementById('done-msg') as HTMLElement).textContent = randomAchievement();
    btn.style.display = 'none';
    const doneState = document.getElementById('done-state') as HTMLElement;
    doneState.classList.add('visible');
    (document.getElementById('today-question') as HTMLElement).textContent = 'やった。';
    (document.getElementById('today-question') as HTMLElement).style.opacity = '0.35';
    (document.getElementById('streak-number') as HTMLElement).textContent = String(streak);
    (document.getElementById('total-count') as HTMLElement).textContent =
      String(data.completedDates.length);

    btn.classList.remove('completing');
    btn.disabled = false;
  }, 380);
}

// ================================================
// 記録ビュー
// ================================================
const WEEKDAYS_JA = ['日','月','火','水','木','金','土'];
const MONTHS_JA   = ['1月','2月','3月','4月','5月','6月',
                     '7月','8月','9月','10月','11月','12月'];

function renderRecord(): void {
  const data = getData();
  const doneSet = new Set(data.completedDates);
  const streak = calcStreak(data.completedDates);
  const today = getToday();

  const year  = calMonth.getFullYear();
  const month = calMonth.getMonth();

  // 統計
  (document.getElementById('rec-streak') as HTMLElement).textContent = String(streak);
  (document.getElementById('rec-total') as HTMLElement).textContent =
    String(data.completedDates.length);
  (document.getElementById('rec-month') as HTMLElement).textContent =
    String(monthCount(data.completedDates, year, month));
  (document.getElementById('month-label') as HTMLElement).textContent =
    `${year}年${MONTHS_JA[month]}`;

  // カレンダーグリッド
  const grid = document.getElementById('cal-grid') as HTMLElement;
  grid.innerHTML = '';

  const firstDow = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();

  // 先頭の空白
  for (let i = 0; i < firstDow; i++) {
    const blank = document.createElement('div');
    blank.className = 'cal-day';
    blank.setAttribute('aria-hidden', 'true');
    grid.appendChild(blank);
  }

  // 日付セル
  for (let d = 1; d <= daysInMonth; d++) {
    const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isDone   = doneSet.has(ds);
    const isToday  = ds === today;
    const isFuture = ds > today;

    const cell = document.createElement('div');
    const classes = ['cal-day'];
    if (isDone)   classes.push('done');
    if (isToday)  classes.push('today');
    if (isFuture) classes.push('future');
    cell.className = classes.join(' ');
    cell.setAttribute('role', 'gridcell');
    cell.setAttribute('aria-label', `${d}日${isDone ? '（達成）' : ''}`);

    const numEl = document.createElement('span');
    numEl.className = 'cal-day-num';
    numEl.textContent = String(d);
    cell.appendChild(numEl);

    if (isDone) {
      const dot = document.createElement('div');
      dot.className = 'cal-dot';
      dot.setAttribute('aria-hidden', 'true');
      cell.appendChild(dot);
    }

    grid.appendChild(cell);
  }
}

// ================================================
// 設定ビュー
// ================================================
function renderSettings(): void {
  const data = getData();
  (document.getElementById('notif-toggle') as HTMLInputElement).checked =
    data.notificationEnabled;
  (document.getElementById('notif-time') as HTMLInputElement).value =
    data.notificationTime;
  (document.getElementById('notif-style') as HTMLSelectElement).value =
    data.notificationStyle;
  updateNotifStatus();
}

function updateNotifStatus(): void {
  const el = document.getElementById('notif-status-text') as HTMLElement;
  if (!('Notification' in window)) {
    el.textContent = 'このブラウザはWeb通知に対応していません。';
    return;
  }
  if (Notification.permission === 'denied') {
    el.textContent =
      '通知がブロックされています。ブラウザの設定から許可してください。';
    return;
  }
  if (Notification.permission === 'granted') {
    el.textContent =
      '通知の許可が取得済みです。ホーム画面に追加してインストール済みの場合、バックグラウンドでも通知が届きます。';
    return;
  }
  el.textContent =
    '通知をONにすると、毎日リマインドをお届けします。';
}

async function handleNotifToggle(enabled: boolean): Promise<void> {
  const data = getData();

  if (enabled) {
    if (!('Notification' in window) || !('PushManager' in window)) {
      showAlert('通知を使うにはホーム画面に追加（PWAインストール）が必要です。\nSafariの共有ボタン →「ホーム画面に追加」してください。');
      (document.getElementById('notif-toggle') as HTMLInputElement).checked = false;
      return;
    }
    if (Notification.permission !== 'granted') {
      const perm = await Notification.requestPermission();
      if (perm !== 'granted') {
        (document.getElementById('notif-toggle') as HTMLInputElement).checked = false;
        updateNotifStatus();
        return;
      }
    }
    data.notificationEnabled = true;
    saveData(data);
    await subscribeToServer();
  } else {
    data.notificationEnabled = false;
    saveData(data);
    await unsubscribeFromServer();
  }
  updateNotifStatus();
}

// ================================================
// VAPID プッシュ通知
// ================================================
function urlBase64ToUint8Array(base64String: string): Uint8Array {
  const padding = '='.repeat((4 - (base64String.length % 4)) % 4);
  const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  const rawData = atob(base64);
  return Uint8Array.from([...rawData].map((c) => c.charCodeAt(0)));
}

async function subscribeToServer(): Promise<void> {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  const reg = await navigator.serviceWorker.ready;
  const data = getData();

  try {
    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY),
    });
    await fetch(`${WORKER_URL}/subscribe`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        subscription: sub.toJSON(),
        notifTime: data.notificationTime,
        notifStyle: data.notificationStyle,
      }),
    });
  } catch (e) {
    console.warn('Push subscription failed:', e);
  }
}

async function unsubscribeFromServer(): Promise<void> {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  try {
    const reg = await navigator.serviceWorker.ready;
    const sub = await reg.pushManager.getSubscription();
    if (!sub) return;
    await fetch(`${WORKER_URL}/subscribe`, {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ endpoint: sub.endpoint }),
    });
    await sub.unsubscribe();
  } catch (e) {
    console.warn('Unsubscribe failed:', e);
  }
}

async function updateServerSubscription(): Promise<void> {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  try {
    const reg = await navigator.serviceWorker.ready;
    const sub = await reg.pushManager.getSubscription();
    if (!sub) return;
    const data = getData();
    await fetch(`${WORKER_URL}/subscribe`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        subscription: sub.toJSON(),
        notifTime: data.notificationTime,
        notifStyle: data.notificationStyle,
      }),
    });
  } catch (e) {
    console.warn('Update subscription failed:', e);
  }
}

async function sendTestNotification(): Promise<void> {
  if (!('Notification' in window)) {
    showAlert('このブラウザは通知に対応していません。\nホーム画面に追加してから試してください。');
    return;
  }
  if (Notification.permission !== 'granted') {
    const perm = await Notification.requestPermission();
    if (perm !== 'granted') {
      showAlert('通知の許可が必要です。');
      return;
    }
  }
  try {
    const reg = await navigator.serviceWorker.ready;
    await reg.showNotification('Push One', {
      body: 'テスト通知です。1回やった ✓ を押してみてください。',
      icon: '/icons/icon-192.svg',
      tag: 'push-one-test',
      requireInteraction: false,
      actions: [
        { action: 'done', title: '1回やった ✓' },
        { action: 'later', title: 'あとで' },
      ],
    });
  } catch (e) {
    console.warn('Notification failed:', e);
  }
}

// ================================================
// カスタム確認ダイアログ
// ================================================
function showConfirm(title: string, body: string, onConfirm: () => void): void {
  const overlay = document.createElement('div');
  overlay.className = 'confirm-overlay';
  overlay.innerHTML = `
    <div class="confirm-sheet" role="dialog" aria-modal="true" aria-labelledby="conf-title">
      <p class="confirm-title" id="conf-title">${title}</p>
      <p class="confirm-body">${body}</p>
      <div class="confirm-actions">
        <button class="confirm-danger" id="conf-ok">リセットする</button>
        <button class="confirm-cancel" id="conf-cancel">キャンセル</button>
      </div>
    </div>
  `;
  document.body.appendChild(overlay);

  (overlay.querySelector('#conf-ok') as HTMLButtonElement).addEventListener('click', () => {
    overlay.remove();
    onConfirm();
  });
  (overlay.querySelector('#conf-cancel') as HTMLButtonElement).addEventListener('click', () => {
    overlay.remove();
  });
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.remove();
  });
}

function showAlert(msg: string): void {
  const overlay = document.createElement('div');
  overlay.className = 'confirm-overlay';
  overlay.innerHTML = `
    <div class="confirm-sheet" role="alertdialog" aria-modal="true">
      <p class="confirm-body" style="text-align:center;">${msg}</p>
      <div class="confirm-actions">
        <button class="confirm-cancel" id="alert-ok">OK</button>
      </div>
    </div>
  `;
  document.body.appendChild(overlay);
  (overlay.querySelector('#alert-ok') as HTMLButtonElement).addEventListener('click', () =>
    overlay.remove()
  );
}

// ================================================
// Service Worker 登録
// ================================================
async function registerSW(): Promise<void> {
  if (!('serviceWorker' in navigator)) return;
  try {
    const reg = await navigator.serviceWorker.register('/sw.js');
    console.log('[Push One] SW registered:', reg.scope);

    // SW → メインスレッドへのメッセージ処理
    navigator.serviceWorker.addEventListener('message', (event) => {
      if (event.data?.type === 'COMPLETE_TODAY') {
        handleComplete();
      }
    });
  } catch (e) {
    console.warn('[Push One] SW registration failed:', e);
  }
}

// ================================================
// 初期化
// ================================================
function init(): void {
  // SW登録
  registerSW();

  // URLパラメータ確認（通知アクションからの起動）
  if (location.search.includes('action=complete') && !isTodayDone()) {
    handleComplete();
  }

  // ホームビュー描画
  renderHome();

  // ===== ナビゲーション =====
  document.querySelectorAll<HTMLButtonElement>('.nav-item').forEach((btn) => {
    btn.addEventListener('click', () => switchView(btn.dataset.view!));
  });

  // ===== ホームビュー =====
  document.getElementById('complete-btn')!.addEventListener('click', handleComplete);

  // ===== 記録ビュー =====
  document.getElementById('prev-month')!.addEventListener('click', () => {
    calMonth.setMonth(calMonth.getMonth() - 1);
    renderRecord();
  });
  document.getElementById('next-month')!.addEventListener('click', () => {
    calMonth.setMonth(calMonth.getMonth() + 1);
    renderRecord();
  });

  // ===== 設定ビュー =====
  document.getElementById('notif-toggle')!.addEventListener('change', (e) => {
    handleNotifToggle((e.target as HTMLInputElement).checked);
  });

  document.getElementById('notif-time')!.addEventListener('change', (e) => {
    const data = getData();
    data.notificationTime = (e.target as HTMLInputElement).value;
    saveData(data);
    if (data.notificationEnabled) updateServerSubscription();
  });

  document.getElementById('notif-style')!.addEventListener('change', (e) => {
    const data = getData();
    data.notificationStyle = (e.target as HTMLSelectElement).value;
    saveData(data);
    if (data.notificationEnabled) updateServerSubscription();
  });

  document.getElementById('test-notif-btn')!.addEventListener('click', sendTestNotification);

  document.getElementById('reset-btn')!.addEventListener('click', () => {
    showConfirm(
      'データをリセット',
      '達成記録がすべて削除されます。この操作は取り消せません。',
      () => {
        localStorage.removeItem(STORAGE_KEY);
        renderHome();
        if (currentView === 'record') renderRecord();
        if (currentView === 'settings') renderSettings();
      }
    );
  });

}

// スプラッシュを800ms後に非表示
setTimeout(hideSplash, 800);

// DOMContentLoaded 相当（Astroのモジュールスクリプトはdeferred）
init();
</script>
